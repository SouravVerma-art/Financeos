<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>404 — FinanceOS</title>
  <link rel="stylesheet" href="/css/main.css" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=Space+Mono&display=swap" rel="stylesheet" />
  <style>
    .not-found { display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:80vh;text-align:center;gap:16px; }
    .not-found-code { font-size:96px;font-weight:800;color:rgba(0,255,178,0.15);letter-spacing:-4px;line-height:1; }
    .not-found-title { font-size:24px;font-weight:700; }
    .not-found-sub { color:rgba(255,255,255,0.4);font-family:'Space Mono',monospace;font-size:14px; }
  </style>
</head>
<body>
  <div class="not-found">
    <div class="not-found-code">404</div>
    <div class="not-found-title">Page Not Found</div>
    <div class="not-found-sub">The page you're looking for doesn't exist.</div>
    <a href="/dashboard" class="btn-primary" style="margin-top:8px">← Back to Dashboard</a>
  </div>
</body>
</html>
