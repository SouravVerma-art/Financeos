
<div class="form-page">
  <div class="page-header">
    <div>
      <h1 class="page-title">Add Transaction</h1>
      <p class="page-sub">Record a new income or expense</p>
    </div>
    <a href="/transactions" class="btn-ghost">← Back</a>
  </div>

  <div class="glow-card form-card">
    <form action="/transactions" method="POST" class="tx-form">
      <div class="form-row">
        <div class="form-group">
          <label>Transaction Name *</label>
          <input type="text" name="name" placeholder="e.g. Grocery Store" required />
        </div>
        <div class="form-group">
          <label>Amount *</label>
          <div class="input-prefix-wrap">
            <span class="input-prefix">$</span>
            <input type="number" name="amount" placeholder="0.00" step="0.01" min="0.01" required />
          </div>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Type *</label>
          <div class="type-toggle">
            <input type="radio" id="expense" name="type" value="expense" checked />
            <label for="expense" class="type-label type-expense">Expense</label>
            <input type="radio" id="income" name="type" value="income" />
            <label for="income" class="type-label type-income">Income</label>
          </div>
        </div>
        <div class="form-group">
          <label>Category *</label>
          <select name="category" required>
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>"><%= cat %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Date</label>
          <input type="date" name="date" value="<%= new Date().toISOString().split('T')[0]%>" />
        </div>
        <div class="form-group">
          <label>Note (optional)</label>
          <input type="text" name="note" placeholder="Add a note..." />
        </div>
      </div>

      <div class="form-actions">
        <a href="/transactions" class="btn-ghost">Cancel</a>
        <button type="submit" class="btn-primary">Add Transaction</button>
      </div>
    </form>
  </div>
</div>
