
<div class="form-page">
  <div class="page-header">
    <div>
      <h1 class="page-title">Edit Transaction</h1>
      <p class="page-sub">Update transaction details</p>
    </div>
    <a href="/transactions" class="btn-ghost">← Back</a>
  </div>

  <div class="glow-card form-card">
    <form action="/transactions/<%= tx._id %>?_method=PUT" method="POST" class="tx-form">
      <div class="form-row">
        <div class="form-group">
          <label>Transaction Name *</label>
          <input type="text" name="name" value="<%= tx.name %>" required />
        </div>
        <div class="form-group">
          <label>Amount *</label>
          <div class="input-prefix-wrap">
            <span class="input-prefix">$</span>
            <input type="number" name="amount" value="<%= tx.amount %>" step="0.01" min="0.01" required />
          </div>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Type *</label>
          <div class="type-toggle">
            <input type="radio" id="expense" name="type" value="expense" <%= tx.type === 'expense' ? 'checked' : '' %> />
            <label for="expense" class="type-label type-expense">Expense</label>
            <input type="radio" id="income" name="type" value="income" <%= tx.type === 'income' ? 'checked' : '' %> />
            <label for="income" class="type-label type-income">Income</label>
          </div>
        </div>
        <div class="form-group">
          <label>Category</label>
          <select name="category">
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= tx.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Date</label>
          <input type="date" name="date" value="<%= new Date(tx.date).toISOString().split('T')[0] %>" />
        </div>
        <div class="form-group">
          <label>Note</label>
          <input type="text" name="note" value="<%= tx.note || '' %>" placeholder="Optional note..." />
        </div>
      </div>

      <div class="form-actions">
        <a href="/transactions" class="btn-ghost">Cancel</a>
        <button type="submit" class="btn-primary">Update Transaction</button>
      </div>
    </form>
  </div>
</div>
